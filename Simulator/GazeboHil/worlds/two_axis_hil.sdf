<?xml version="1.0" ?>
<sdf version="1.9">
    <world name="two_axis_world">

        <physics name="1ms" type="ode">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>

        <plugin
                filename="gz-sim-physics-system"
                name="gz::sim::systems::Physics"/>

        <plugin
                filename="gz-sim-scene-broadcaster-system"
                name="gz::sim::systems::SceneBroadcaster"/>

        <model name="two_axis_rig">
            <pose>0 0 1 0 0 0</pose>

            <link name="base">
                <visual name="base_visual">
                    <geometry>
                        <box>
                            <size>0.25 0.25 0.15</size>
                        </box>
                    </geometry>
                </visual>
                <collision name="base_collision">
                    <geometry>
                        <box>
                            <size>0.25 0.25 0.15</size>
                        </box>
                    </geometry>
                </collision>
                <inertial>
                    <mass>5.0</mass>
                    <inertia>
                        <ixx>1</ixx>
                        <iyy>1</iyy>
                        <izz>1</izz>
                    </inertia>
                </inertial>
            </link>

            <joint name="world_to_base" type="fixed">
                <parent>world</parent>
                <child>base</child>
            </joint>

            <!-- проміжна рамка для roll -->
            <link name="roll_frame">
                <visual name="roll_frame_visual">
                    <geometry>
                        <box>
                            <size>0.12 0.12 0.12</size>
                        </box>
                    </geometry>
                </visual>
                <collision name="roll_frame_collision">
                    <geometry>
                        <box>
                            <size>0.12 0.12 0.12</size>
                        </box>
                    </geometry>
                </collision>
                <inertial>
                    <mass>0.1</mass>
                    <inertia>
                        <ixx>0.01</ixx>
                        <iyy>0.01</iyy>
                        <izz>0.01</izz>
                    </inertia>
                </inertial>
            </link>

            <joint name="roll_joint" type="revolute">
                <parent>base</parent>
                <child>roll_frame</child>
                <axis>
                    <xyz>1 0 0</xyz>
                    <limit>
                        <lower>-1.5708</lower>
                        <upper>1.5708</upper>
                        <effort>10.0</effort>
                        <velocity>20.0</velocity>
                    </limit>
                    <dynamics>
                        <damping>0.02</damping>
                    </dynamics>
                </axis>
            </joint>

            <!-- основне тіло, яке нахиляється по pitch -->
            <link name="body">
                <pose>0 0 0 0 0 0</pose>
                <visual name="body_visual">
                    <geometry>
                        <box>
                            <size>0.8 0.8 0.05</size>
                        </box>
                    </geometry>
                </visual>
                <collision name="body_collision">
                    <geometry>
                        <box>
                            <size>0.8 0.8 0.05</size>
                        </box>
                    </geometry>
                </collision>
                <inertial>
                    <mass>0.5</mass>
                    <inertia>
                        <ixx>0.03</ixx>
                        <iyy>0.03</iyy>
                        <izz>0.05</izz>
                    </inertia>
                </inertial>
            </link>

            <joint name="pitch_joint" type="revolute">
                <parent>roll_frame</parent>
                <child>body</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit>
                        <lower>-1.5708</lower>
                        <upper>1.5708</upper>
                        <effort>10.0</effort>
                        <velocity>20.0</velocity>
                    </limit>
                    <dynamics>
                        <damping>0.02</damping>
                    </dynamics>
                </axis>
            </joint>

            <plugin
                    filename="libHilPlugin"
                    name="hil_plugin::HilPlugin">

                <roll_joint_name>roll_joint</roll_joint_name>
                <pitch_joint_name>pitch_joint</pitch_joint_name>

                <serial_port>/dev/cu.usbmodem1103</serial_port>
                <baud>115200</baud>

                <max_roll_torque>0.15</max_roll_torque>
                <max_pitch_torque>0.15</max_pitch_torque>

                <roll_torque_sign>1.0</roll_torque_sign>
                <pitch_torque_sign>1.0</pitch_torque_sign>

                <hil_rate_hz>100</hil_rate_hz>

                <disturbance_roll_torque>0.05</disturbance_roll_torque>
                <disturbance_pitch_torque>-0.08</disturbance_pitch_torque>
                <disturbance_start>0.2</disturbance_start>
                <disturbance_end>0.6</disturbance_end>

                <log_path>two_axis_hil_log.csv</log_path>
                <log_rate_hz>50</log_rate_hz>
            </plugin>

        </model>
    </world>
</sdf>